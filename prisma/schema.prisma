generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model calculo_frete {
  id             String   @id @db.Char(36)
  carrinho_id    String   @db.Char(36)
  cep            String   @db.Char(8)
  transportadora String?  @db.VarChar(100)
  valor_frete    Decimal  @default(0.00) @db.Decimal(10, 2)
  prazo_entrega  Int
  consultado_em  DateTime @default(now()) @db.DateTime(0)
  carrinho       carrinho @relation(fields: [carrinho_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_frete_carrinho")

  @@index([carrinho_id], map: "fk_frete_carrinho")
}

model calculo_totais {
  id           String   @id @db.Char(36)
  carrinho_id  String   @unique(map: "uq_calc_carrinho") @db.Char(36)
  subtotal     Decimal  @default(0.00) @db.Decimal(12, 2)
  impostos     Decimal  @default(0.00) @db.Decimal(12, 2)
  desconto     Decimal  @default(0.00) @db.Decimal(12, 2)
  frete        Decimal  @default(0.00) @db.Decimal(12, 2)
  total        Decimal  @default(0.00) @db.Decimal(12, 2)
  calculado_em DateTime @default(now()) @db.DateTime(0)
  carrinho     carrinho @relation(fields: [carrinho_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_calc_carrinho")
}

model carrinho {
  id                    String                 @id @db.Char(36)
  usuario_id            String?                @db.Char(36)
  session_id            String?                @db.VarChar(128)
  status                String                 @default("ATIVO") @db.VarChar(20)
  cupom_id              String?                @db.Char(36)
  data_criacao          DateTime               @default(now()) @db.DateTime(0)
  data_expiracao        DateTime?              @db.DateTime(0)
  data_atualizacao      DateTime               @default(now()) @db.DateTime(0)
  calculo_frete         calculo_frete[]
  calculo_totais        calculo_totais?
  cupom                 cupom?                 @relation(fields: [cupom_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_carr_cupom")
  status_carrinho       status_carrinho        @relation(fields: [status], references: [valor], onUpdate: Restrict, map: "fk_carr_status")
  usuario               usuario?               @relation(fields: [usuario_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_carr_usuario")
  item_carrinho         item_carrinho[]
  persistencia_carrinho persistencia_carrinho?
  validacao_estoque     validacao_estoque[]

  @@index([cupom_id], map: "fk_carr_cupom")
  @@index([status], map: "fk_carr_status")
  @@index([usuario_id], map: "fk_carr_usuario")
}

model cupom {
  id                                               String        @id @db.Char(36)
  codigo                                           String        @unique(map: "uq_cupom_cod") @db.VarChar(50)
  tipo_desconto                                    String        @db.VarChar(20)
  valor_desconto                                   Decimal       @default(0.00) @db.Decimal(12, 2)
  data_validade                                    DateTime      @db.DateTime(0)
  usos_maximos                                     Int           @default(1)
  usos_realizados                                  Int           @default(0)
  ativo                                            Boolean       @default(true)
  carrinho                                         carrinho[]
  tipo_desconto_cupom_tipo_descontoTotipo_desconto tipo_desconto @relation("cupom_tipo_descontoTotipo_desconto", fields: [tipo_desconto], references: [valor], onUpdate: Restrict, map: "fk_cupom_tipo")

  @@index([tipo_desconto], map: "fk_cupom_tipo")
}

model item_carrinho {
  id             String   @id @db.Char(36)
  carrinho_id    String   @db.Char(36)
  produto_id     String   @db.Char(36)
  quantidade     Int      @default(1)
  preco_unitario Decimal  @db.Decimal(12, 2)
  carrinho       carrinho @relation(fields: [carrinho_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_item_carrinho")
  produto        produto  @relation(fields: [produto_id], references: [id], onUpdate: Restrict, map: "fk_item_produto")

  @@unique([carrinho_id, produto_id], map: "uq_item")
  @@index([produto_id], map: "fk_item_produto")
}

model persistencia_carrinho {
  id                String            @id @db.Char(36)
  carrinho_id       String            @unique(map: "uq_persist_carrinho") @db.Char(36)
  estrategia        String            @default("SESSION_STORAGE") @db.VarChar(20)
  session_id        String?           @db.VarChar(128)
  usuario_id        String?           @db.Char(36)
  sincronizado_em   DateTime?         @db.DateTime(0)
  carrinho          carrinho          @relation(fields: [carrinho_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_persist_carrinho")
  tipo_persistencia tipo_persistencia @relation(fields: [estrategia], references: [valor], onUpdate: Restrict, map: "fk_persist_estrategia")

  @@index([estrategia], map: "fk_persist_estrategia")
}

model produto {
  id                 String              @id @db.Char(36)
  nome               String              @db.VarChar(255)
  sku                String              @unique(map: "uq_prod_sku") @db.VarChar(100)
  preco              Decimal             @db.Decimal(12, 2)
  estoque_disponivel Int                 @default(0)
  item_carrinho      item_carrinho[]
  validacao_estoque  validacao_estoque[]
}

model status_carrinho {
  valor    String     @id @db.VarChar(20)
  carrinho carrinho[]
}

model tipo_desconto {
  valor                                    String  @id @db.VarChar(20)
  cupom_cupom_tipo_descontoTotipo_desconto cupom[] @relation("cupom_tipo_descontoTotipo_desconto")
}

model tipo_persistencia {
  valor                 String                  @id @db.VarChar(20)
  persistencia_carrinho persistencia_carrinho[]
}

model usuario {
  id        String     @id @db.Char(36)
  nome      String     @db.VarChar(150)
  email     String     @unique(map: "uq_user_email") @db.VarChar(255)
  criado_em DateTime   @default(now()) @db.DateTime(0)
  carrinho  carrinho[]
}

model validacao_estoque {
  id             String   @id @db.Char(36)
  produto_id     String   @db.Char(36)
  carrinho_id    String   @db.Char(36)
  qtd_solicitada Int
  disponivel     Boolean  @default(false)
  validado_em    DateTime @default(now()) @db.DateTime(0)
  carrinho       carrinho @relation(fields: [carrinho_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_val_carrinho")
  produto        produto  @relation(fields: [produto_id], references: [id], onUpdate: Restrict, map: "fk_val_produto")

  @@index([carrinho_id], map: "fk_val_carrinho")
  @@index([produto_id], map: "fk_val_produto")
}
